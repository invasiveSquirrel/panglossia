# .gitignore for Polyglossia

# Node
node_modules/
dist/
dist-ssr/
*.local

# Python
backend/venv/
backend/venv*/
backend/__pycache__/
backend/*.py[cod]
backend/*.log

# Data
*.md
!README.md
!german_vocab.md
!spanish_vocab.md
!finnish_vocab.md
!dutch_vocab.md
!swedish_vocab.md
!portuguese_vocab.md

# Credentials (IMPORTANT)
google-credentials.json
.env
*.key
*.pem

# API Keys and Secrets
*_api.txt
*_api_key.txt
wordhord_api.txt
panglossia_api.txt
api_credentials.json

# Prompts (sensitive content)
backend/prompts/
backend/prompts/*.txt

# OS
.DS_Store
Thumbs.db

# Electron logs
electron.log
